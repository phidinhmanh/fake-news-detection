   "source": [
    "# 🎓 Fake News Detection — Cross-Validation Training\n",
    "\n",
    "**So sánh Baseline TF-IDF vs LoRA XLM-RoBERTa với 5-Fold Cross-Validation**\n",
    "\n",
    "### Mục tiêu:\n",
    "- Train và evaluate 2 models với cross-validation\n",
    "- So sánh performance một cách statistical\n",
    "- Lưu kết quả để phân tích"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 📦 Setup & Imports\n",
    "import sys\n",
    "sys.path.insert(0, \"..\")\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from pathlib import Path\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "print(\"✅ Imports successful!\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 📥 Load FakeNewsNet Data\n",
    "print(\"📥 Loading FakeNewsNet data...\")\n",
    "\n",
    "df = pd.read_csv(\"../data/raw/fakenewsnet_clean.csv\")\n",
    "print(f\"Total samples: {len(df)}\")\n",
    "\n",
    "# Prepare data\n",
    "X = df['text'].fillna(\"\").values\n",
    "y = df['label'].values\n",
    "\n",
    "# Encode labels\n",
    "from sklearn.preprocessing import LabelEncoder\n",
    "le = LabelEncoder()\n",
    "y_encoded = le.fit_transform(y)  # fake=0, real=1\n",
    "\n",
    "print(f\"Class distribution: {pd.Series(y).value_counts().to_dict()}\")\n",
    "print(f\"Label encoding: {dict(zip(le.classes_, range(len(le.classes_))))}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 🔧 MODEL 1: Baseline TF-IDF + LogisticRegression (5-Fold CV)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.model_selection import StratifiedKFold\n",
    "from sklearn.feature_extraction.text import TfidfVectorizer\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.metrics import accuracy_score, f1_score, precision_score, recall_score, roc_auc_score, classification_report\n",
    "from sklearn.pipeline import Pipeline\n",
    "import time\n",
    "\n",
    "def train_baseline_cv(X, y, n_splits=5):\n",
    "    \"\"\"Train Baseline TF-IDF + LogReg với Cross-Validation.\"\"\"\n",
    "    \n",
    "    skf = StratifiedKFold(n_splits=n_splits, shuffle=True, random_state=42)\n",
    "    \n",
    "    results = {\n",
    "        'fold': [],\n",
    "        'accuracy': [],\n",
    "        'f1': [],\n",
    "        'precision': [],\n",
    "        'recall': [],\n",
    "        'auc': [],\n",
    "        'time': []\n",
    "    }\n",
    "    \n",
    "    print(f\"\\n{'='*60}\")\n",
    "    print(f\"🚀 Baseline TF-IDF + LogReg ({n_splits}-Fold CV)\")\n",
    "    print(f\"{'='*60}\\n\")\n",
    "    \n",
    "    for fold, (train_idx, val_idx) in enumerate(skf.split(X, y), 1):\n",
    "        print(f\"Fold {fold}/{n_splits}...\")\n",
    "        start_time = time.time()\n",
    "        \n",
    "        X_train, X_val = X[train_idx], X[val_idx]\n",
    "        y_train, y_val = y[train_idx], y[val_idx]\n",
    "        \n",
    "        # Create pipeline\n",
    "        pipeline = Pipeline([\n",
    "            ('tfidf', TfidfVectorizer(max_features=5000, ngram_range=(1, 2))),\n",
    "            ('clf', LogisticRegression(max_iter=1000, class_weight='balanced'))\n",
    "        ])\n",
    "        \n",
    "        # Train\n",
    "        pipeline.fit(X_train, y_train)\n",
    "        \n",
    "        # Predict\n",
    "        y_pred = pipeline.predict(X_val)\n",
    "        y_proba = pipeline.predict_proba(X_val)[:, 1]  # P(fake)\n",
    "        \n",
    "        # Metrics\n",
    "        acc = accuracy_score(y_val, y_pred)\n",
    "        f1 = f1_score(y_val, y_pred, pos_label=0)  # fake=0\n",
    "        prec = precision_score(y_val, y_pred, pos_label=0)\n",
    "        rec = recall_score(y_val, y_pred, pos_label=0)\n",
    "        auc = roc_auc_score(y_val, y_proba)\n",
    "        elapsed = time.time() - start_time\n",
    "        \n",
    "        results['fold'].append(fold)\n",
    "        results['accuracy'].append(acc)\n",
    "        results['f1'].append(f1)\n",
    "        results['precision'].append(prec)\n",
    "        results['recall'].append(rec)\n",
    "        results['auc'].append(auc)\n",
    "        results['time'].append(elapsed)\n",
    "        \n",
    "        print(f\"  Acc: {acc:.4f} | F1: {f1:.4f} | AUC: {auc:.4f} | Time: {elapsed:.1f}s\")\n",
    "    \n",
    "    # Summary\n",
    "    print(f\"\\n{'='*60}\")\n",
    "    print(\"📊 Baseline CV Results Summary\")\n",
    "    print(f\"{'='*60}\")\n",
    "    \n",
    "    results_df = pd.DataFrame(results)\n",
    "    summary = {\n",
    "        'accuracy': f\"{results_df['accuracy'].mean():.4f} ± {results_df['accuracy'].std():.4f}\",\n",
    "        'f1': f\"{results_df['f1'].mean():.4f} ± {results_df['f1'].std():.4f}\",\n",
    "        'precision': f\"{results_df['precision'].mean():.4f} ± {results_df['precision'].std():.4f}\",\n",
    "        'recall': f\"{results_df['recall'].mean():.4f} ± {results_df['recall'].std():.4f}\",\n",
    "        'auc': f\"{results_df['auc'].mean():.4f} ± {results_df['auc'].std():.4f}\",\n",
    "    }\n",
    "    \n",
    "    for metric, value in summary.items():\n",
    "        print(f\"  {metric.capitalize()}: {value}\")\n",
    "    \n",
    "    return results_df, summary\n",
    "\n",
    "# Run CV\n",
    "baseline_results, baseline_summary = train_baseline_cv(X, y_encoded, n_splits=5)"
   ]
  },
  {
   "cell_type": "markdown",
